{
  "$schema" : "https://opencode.ai/config.json",
  "model" : "custom/deepseek-chat",
  "provider" : {
    "custom" : {
      "npm" : "@ai-sdk/openai-compatible",
      "name" : "Custom Provider",
      "options" : {
        "baseURL" : "http://localhost:8080/v1",
        "apiKey" : ""
      },
      "models" : {
        "deepseek-chat" : {
          "name" : "deepseek-chat",
          "limit" : {
            "context" : 200000,
            "output" : 8192
          }
        }
      }
    }
  },
  "permission" : {
    "*" : "allow",
    "read" : "allow",
    "edit" : "allow",
    "bash" : "allow"
  }
}